# Environment Variables for Smart Moto Service Center — Frontend

# ─── API Configuration ─────────────────────────────────────────────────────────
# Base URL for the backend API (no trailing slash)
VITE_API_URL=http://localhost:3000/api

# Set to "true" to use mock data (local development without backend)
# Set to "false" to connect to the real backend API
VITE_USE_MOCK_DATA=true

# ─── Authentication ────────────────────────────────────────────────────────────
# Auth token is stored in localStorage under this key when user logs in
# VITE_AUTH_TOKEN_KEY=auth_token
